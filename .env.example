# Backend API URL
VITE_API_URL=http://localhost:3000

# No VITE_SITE_ID needed anymore. On first launch the panel shows a Setup
# screen asking for a one-time device setup code, generated per-panel in
# the dashboard's Devices screen. One deployment now works for any number
# of sites/panels — the site/entry-point/device identity is resolved at
# runtime and persisted in the browser's local storage.
